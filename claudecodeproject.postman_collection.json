  ,
    {
      "name": "Massa de Testes",
      "item": [
        {
          "name": "Criar 30 produtos",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "const token = pm.collectionVariables.get('token');",
                  "",
                  "function postJson(path, body, callback) {",
                  "    pm.sendRequest({",
                  "        url: baseUrl + path,",
                  "        method: 'POST',",
                  "        header: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },",
                  "        body: { mode: 'raw', raw: JSON.stringify(body) }",
                  "    }, callback);",
                  "}",
                  "",
                  "const categoryNames = ['Categoria Teste 1', 'Categoria Teste 2', 'Categoria Teste 3'];",
                  "const categoryIds = [];",
                  "",
                  "function createCategories(index, done) {",
                  "    if (index >= categoryNames.length) { done(); return; }",
                  "    postJson('/categories', { name: categoryNames[index], description: 'Categoria gerada para massa de teste' }, function(err, res) {",
                  "        if (!err && res.code === 201) {",
                  "            categoryIds.push(res.json().id);",
                  "            console.log('Criada: ' + categoryNames[index] + ' (id=' + res.json().id + ')');",
                  "        }",
                  "        createCategories(index + 1, done);",
                  "    });",
                  "}",
                  "",
                  "function createProducts() {",
                  "    for (let i = 1; i <= 30; i++) {",
                  "        const listPrice = parseFloat((Math.random() * 1900 + 100).toFixed(2));",
                  "        const salePrice = parseFloat((listPrice * (Math.random() * 0.4 + 0.6)).toFixed(2));",
                  "        const categoryId = categoryIds[i % categoryIds.length];",
                  "",
                  "        postJson('/products', {",
                  "            name: 'Produto Teste ' + i,",
                  "            description: '<p>Produto gerado automaticamente para massa de teste.</p>',",
                  "            categoryId: categoryId,",
                  "            price: { salePrice: salePrice, listPrice: listPrice },",
                  "            mediaSet: {",
                  "                thumbnail: 'https://example.com/teste-' + i + '-thumb.jpg',",
                  "                medium: 'https://example.com/teste-' + i + '-medium.jpg',",
                  "                large: 'https://example.com/teste-' + i + '-large.jpg'",
                  "            }",
                  "        }, function(err, res) {",
                  "            console.log('Produto Teste ' + i + ': ' + (err ? 'ERRO - ' + err : res.code));",
                  "        });",
                  "    }",
                  "}",
                  "",
                  "createCategories(0, createProducts);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "O script de pré-requisição cria 3 categorias teste e 30 produtos em sequência. Esta requisição lista os resultados após a criação.\n\n**SQL para deletar toda a massa de teste (rodar no DBeaver com ccproject selecionado):**\n```sql\nDELETE p, pr, ms\nFROM product p\nLEFT JOIN price pr ON pr.id = p.price_id\nLEFT JOIN media_set ms ON ms.id = p.media_set_id\nWHERE p.name LIKE 'Produto Teste %';\n\nDELETE FROM category WHERE name LIKE 'Categoria Teste %';\n```",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&size=30",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "30" }
              ]
            }
          }
        }
      ]
    }
